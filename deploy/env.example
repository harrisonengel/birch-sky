# deploy/.env — Copy to .env and fill in real values.
# Generate passwords with: openssl rand -base64 24

# --- Secrets (CHANGE THESE) ---
POSTGRES_PASSWORD=CHANGEME
MINIO_ROOT_USER=ieadmin
MINIO_ROOT_PASSWORD=CHANGEME
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=

# --- Service config (these defaults are usually fine) ---
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_INDEX=listings
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=market-data
MINIO_USE_SSL=false
HTTP_PORT=8080
MCP_PORT=8081
MODEL_NAME=claude-sonnet-4-5
