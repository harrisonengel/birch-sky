{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trace",
  "type": "object",
  "required": ["run_id", "scenario_id", "timestamp", "harness_config", "resolved_inputs", "agent_steps", "recommendations", "buy_listings"],
  "properties": {
    "run_id": {"type": "string"},
    "scenario_id": {"type": "string"},
    "timestamp": {"type": "string", "format": "date-time"},
    "code_version": {"type": "string"},
    "harness_config": {
      "type": "object",
      "required": ["model", "system_prompt_hash"],
      "properties": {
        "model": {"type": "string"},
        "system_prompt_hash": {"type": "string"},
        "market_platform_url": {"type": "string"},
        "seed_fixture_hash": {"type": "string"},
        "note": {"type": "string"}
      }
    },
    "resolved_inputs": {"type": "object"},
    "agent_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "kind"],
        "properties": {
          "step": {"type": "integer"},
          "kind": {"enum": ["reasoning", "tool_call"]},
          "content": {"type": "string"},
          "tool": {"type": "string"},
          "input": {},
          "output": {}
        }
      }
    },
    "recommendations": {
      "type": "array",
      "description": "Raw {seller_id, listing_id} pairs submitted by the agent via submit_buy_recommendation. Structured only; no free text.",
      "items": {
        "type": "object",
        "required": ["seller_id", "listing_id"],
        "properties": {
          "seller_id": {"type": "string"},
          "listing_id": {"type": "string"}
        }
      }
    },
    "buy_listings": {
      "type": "array",
      "description": "Server-hydrated view exactly as /api/enter returns it to the buyer. listing_description and seller are authoritative from the market platform, not the agent.",
      "items": {
        "type": "object",
        "required": ["id", "price", "listing_description", "seller"],
        "properties": {
          "id": {"type": "string"},
          "price": {"type": "integer"},
          "listing_description": {"type": "string"},
          "seller": {"type": "string"}
        }
      }
    },
    "hydration_error": {"type": ["string", "null"]},
    "exception": {
      "type": ["object", "null"],
      "properties": {
        "type": {"type": "string"},
        "message": {"type": "string"},
        "traceback": {"type": "string"}
      }
    }
  }
}
